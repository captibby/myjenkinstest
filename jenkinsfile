pipeline {
    agent any
    parameters {
        choice(name: 'VERSION', choices: ['1.1.0', '1.1.2'], description: '')
    }
    stages {
        stage ("build") {
            steps {
                echo 'building the application..'
            }
        }
        stage ("test")
            when{
                expression {
                    params.executeTests
                }
            }
            steps {
                echo 'testing application..'    
            }
        }
        stage ("deploy") {
            steps {
                echo 'deploying the application..'
            }
        }    
    }
}
