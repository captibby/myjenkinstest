pipeline {
    agent any
    parameters {
        string(name: 'envName', defaultValue: 'main', description: 'main,release,prod')
        string(name: 'testType', defaultValue: 'servicetest', description: 'servicetest or e2etest')
    }
    stages {
        stage ('Greetings') {
            steps {
                echo 'Hi, how are you ?'
            }
        }    
        stage ('Response') {
            steps {
                sh ('sleep 2')
                powershell(". '.\\test.ps1' ")
            }
        }
        stage ('Farewell') { 
            steps {
                echo 'Have a great Day!'
            }
        }
        stage ('Send an email') {
            steps {
                emailext (to: 'zakariahmed226@gmail.com', replyTo: 'zakariahmed226@gmail.com', subject: "Email Report from - '${env.JOB_NAME}' ", body: echo ("successful"), mimeType: 'text/html');
            }
        }
    }
}
