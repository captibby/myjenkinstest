pipeline {
    agent any
    parameters {
        string(name: 'envName', defaultValue: 'main', description: 'main,release,prod')
        string(name: 'testType', defaultValue: 'servicetest', description: 'servicetest or e2etest')
    }
    stages {
        stage ('Greetings') {
            steps {
                echo 'Hi, how are you ?'
            }
        }    
        stage {
            steps {
                sh 'hi.sh'
            }
        }
        stage {
            steps {
                echo 'weldone'
            }
        }
    }
}
